{% extends 'base.html.twig' %}

{% block title %}Recherche de trajet{% endblock %}

{% block body %}
	<div class="container py-4">
		{{ include('front/_partials/_search_ride/_search_ride.html.twig', {
			depart: depart,
			arrivee: arrivee,
			departAt: departAt
		}) }}
	</div>

	<div class="container pb-5">
		<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
			<div>
				<h1 class="h3 mb-1 text-secondary">Trajets disponibles</h1>
				<p class="text-muted mb-0">
					{% if hasFilters %}
						{{ trips|length }} trajet{{ trips|length > 1 ? 's' : '' }} trouv{{ trips|length > 1 ? 'es' : 'e' }} pour ta recherche.
					{% else %}
						Voici les prochains covoiturages disponibles sur EcoRide.
					{% endif %}
				</p>
			</div>
		</div>

		{% if trips is empty %}
			<div class="alert alert-info border-0 shadow-sm rounded-4 p-4">
				<h2 class="h5 mb-2">Aucun trajet disponible</h2>
				<p class="mb-0">Essaie avec une autre ville de départ, une autre arrivée ou une autre date de départ.</p>
			</div>
		{% else %}
			<div class="row g-4">
				{% for trip in trips %}
					<div class="col-12 col-lg-6">
						<article class="card border-0 shadow-sm rounded-4 h-100 trip-card">
							<div class="card-body p-4">
								<div class="d-flex justify-content-between align-items-start gap-3 mb-3">
									<div>
										<div class="small text-uppercase text-muted mb-1">Trajet</div>
										<h2 class="h4 mb-0 text-secondary">{{ trip.originCity }} <span class="text-primary">→</span> {{ trip.destinationCity }}</h2>
									</div>
									<div class="text-end">
										<div class="badge text-bg-success fs-6">{{ trip.priceCredits }} credits</div>
										{% if trip.ecoTag %}
											<div class="badge text-bg-light border text-success mt-2">Vehicule electrique</div>
										{% endif %}
									</div>
								</div>

								<div class="row g-3 mb-3">
									<div class="col-6">
										<div class="small text-muted">Depart</div>
										<div class="fw-semibold">{{ trip.departureAt|date('d/m/Y') }}</div>
										<div>{{ trip.departureAt|date('H:i') }}</div>
									</div>
									<div class="col-6">
										<div class="small text-muted">Arrivee</div>
										<div class="fw-semibold">{{ trip.arrivalAt|date('d/m/Y') }}</div>
										<div>{{ trip.arrivalAt|date('H:i') }}</div>
									</div>
									<div class="col-6">
										<div class="small text-muted">Conducteur</div>
										<div class="fw-semibold">{{ trip.driver.pseudo ?? trip.driver.firstName }}</div>
										<div class="text-muted small">{{ trip.driver.firstName }} {{ trip.driver.lastName }}</div>
									</div>
									<div class="col-6">
										<div class="small text-muted">Vehicule</div>
										<div class="fw-semibold">{{ trip.vehicle.brand }} {{ trip.vehicle.model }}</div>
										<div class="text-muted small">{{ trip.vehicle.color }} • {{ trip.vehicle.plateNumber }}</div>
									</div>
								</div>

								<div class="d-flex flex-wrap gap-2 align-items-center">
									<span class="badge text-bg-primary">{{ trip.seatsAvailable }} place{{ trip.seatsAvailable > 1 ? 's' : '' }} restante{{ trip.seatsAvailable > 1 ? 's' : '' }}</span>
									<span class="badge text-bg-light border text-dark">{{ trip.durationMinutes }} min</span>
									<span class="badge text-bg-light border text-dark text-capitalize">{{ trip.status }}</span>
								</div>
								<div class="mt-3">
									<a href="{{ path('app_carpooling_show', {id: trip.id}) }}" class="btn btn-outline-primary">Voir le detail du covoiturage</a>
								</div>
							</div>
						</article>
					</div>
				{% endfor %}
			</div>
		{% endif %}
	</div>
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<style>
		.trip-card {
			transition: transform 0.2s ease, box-shadow 0.2s ease;
		}

		.trip-card:hover {
			transform: translateY(-4px);
			box-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.08) !important;
		}
	</style>
{% endblock %}
