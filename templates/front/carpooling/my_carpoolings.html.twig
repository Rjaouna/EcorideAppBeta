{% extends 'base.html.twig' %}

{% block title %}Mes covoiturages{% endblock %}

{% block body %}
	<div class="container py-4">
		<div class="mb-4">
			<h1 class="h3 text-secondary mb-1">Mes covoiturages</h1>
			<p class="text-muted mb-0">Retrouve ici les trajets que tu as publies et les covoiturages auxquels tu participes.</p>
		</div>

		<div class="row g-4">
			<div class="col-12 col-lg-6">
				<div class="card border-0 shadow-sm rounded-4 h-100">
					<div class="card-body p-4">
						<div class="d-flex justify-content-between align-items-center mb-3">
							<h2 class="h5 mb-0 text-secondary">Mes trajets publies</h2>
							<a href="{{ path('app_carpooling_new') }}" class="btn btn-sm btn-primary text-white">Publier un trajet</a>
						</div>

						{% if publishedTrips is empty %}
							<p class="text-muted mb-0">Tu n as pas encore publie de covoiturage.</p>
						{% else %}
							<div class="d-grid gap-3">
								{% for trip in publishedTrips %}
									<div class="border rounded-4 p-3">
										<div class="fw-semibold">{{ trip.originCity }} <span class="text-primary">→</span> {{ trip.destinationCity }}</div>
										<div class="small text-muted mb-2">{{ trip.departureAt|date('d/m/Y H:i') }} • {{ trip.vehicle.brand }} {{ trip.vehicle.model }}</div>
										<div class="d-flex flex-wrap gap-2 align-items-center">
											<span class="badge text-bg-light border text-dark">{{ trip.seatsAvailable }} place{{ trip.seatsAvailable > 1 ? 's' : '' }} restante{{ trip.seatsAvailable > 1 ? 's' : '' }}</span>
											<span class="badge text-bg-light border text-dark">{{ trip.priceCredits }} credits</span>
											<a href="{{ path('app_carpooling_show', {id: trip.id}) }}" class="btn btn-sm btn-outline-primary">Voir le detail</a>
										</div>
									</div>
								{% endfor %}
							</div>
						{% endif %}
					</div>
				</div>
			</div>

			<div class="col-12 col-lg-6">
				<div class="card border-0 shadow-sm rounded-4 h-100">
					<div class="card-body p-4">
						<h2 class="h5 mb-3 text-secondary">Mes participations</h2>

						{% if bookings is empty %}
							<p class="text-muted mb-0">Tu ne participes a aucun covoiturage pour le moment.</p>
						{% else %}
							<div class="d-grid gap-3">
								{% for booking in bookings %}
									<div class="border rounded-4 p-3">
										<div class="fw-semibold">{{ booking.trip.originCity }} <span class="text-primary">→</span> {{ booking.trip.destinationCity }}</div>
										<div class="small text-muted mb-2">{{ booking.trip.departureAt|date('d/m/Y H:i') }} • Conducteur : {{ booking.trip.driver.pseudo ?? booking.trip.driver.firstName }}</div>
										<div class="d-flex flex-wrap gap-2 align-items-center">
											<span class="badge text-bg-light border text-dark text-capitalize">{{ booking.status }}</span>
											<span class="badge text-bg-light border text-dark">{{ booking.trip.priceCredits }} credits</span>
											<a href="{{ path('app_carpooling_show', {id: booking.trip.id}) }}" class="btn btn-sm btn-outline-primary">Voir le detail</a>
										</div>
									</div>
								{% endfor %}
							</div>
						{% endif %}
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
