{% extends 'base.html.twig' %}

{% block title %}Detail du covoiturage{% endblock %}

{% block body %}
	<div class="container py-4">
		<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
			<div>
				<div class="small text-uppercase text-muted">Covoiturage</div>
				<h1 class="h3 mb-1 text-secondary">{{ trip.originCity }} <span class="text-primary">→</span> {{ trip.destinationCity }}</h1>
				<p class="text-muted mb-0">Depart le {{ trip.departureAt|date('d/m/Y') }} a {{ trip.departureAt|date('H:i') }}</p>
			</div>
			<a href="{{ path('app_carpooling_search', {
				depart: trip.originCity,
				arrivee: trip.destinationCity,
				departAt: trip.departureAt|date('Y-m-d')
			}) }}" class="btn btn-outline-secondary">Retour aux covoiturages</a>
		</div>

		<div class="row g-4">
			<div class="col-12 col-lg-8">
				<div class="card border-0 shadow-sm rounded-4 h-100">
					<div class="card-body p-4">
						<div class="row g-4">
							<div class="col-12 col-md-6">
								<div class="small text-muted">Depart</div>
								<div class="fw-semibold">{{ trip.originCity }}</div>
								<div>{{ trip.departureAt|date('d/m/Y') }} a {{ trip.departureAt|date('H:i') }}</div>
							</div>
							<div class="col-12 col-md-6">
								<div class="small text-muted">Arrivee</div>
								<div class="fw-semibold">{{ trip.destinationCity }}</div>
								<div>{{ trip.arrivalAt|date('d/m/Y') }} a {{ trip.arrivalAt|date('H:i') }}</div>
							</div>
							<div class="col-12 col-md-6">
								<div class="small text-muted">Conducteur</div>
								<div class="fw-semibold">{{ trip.driver.pseudo ?? trip.driver.firstName }}</div>
								<div>{{ trip.driver.firstName }} {{ trip.driver.lastName }}</div>
							</div>
							<div class="col-12 col-md-6">
								<div class="small text-muted">Vehicule</div>
								<div class="fw-semibold">{{ trip.vehicle.brand }} {{ trip.vehicle.model }}</div>
								<div>{{ trip.vehicle.color }} • {{ trip.vehicle.plateNumber }}</div>
							</div>
							<div class="col-12 col-md-4">
								<div class="small text-muted">Prix</div>
								<div class="fw-semibold">{{ trip.priceCredits }} credits</div>
							</div>
							<div class="col-12 col-md-4">
								<div class="small text-muted">Duree</div>
								<div class="fw-semibold">{{ trip.durationMinutes }} min</div>
							</div>
							<div class="col-12 col-md-4">
								<div class="small text-muted">Places restantes</div>
								<div class="fw-semibold">{{ trip.seatsAvailable }}</div>
							</div>
						</div>

						{% if trip.driver.driverPreferences %}
							<hr class="my-4">
							<h2 class="h5 mb-3 text-secondary">Preferences du conducteur</h2>
							<div class="d-flex flex-wrap gap-2">
								<span class="badge text-bg-light border text-dark">
									{{ trip.driver.driverPreferences.smokingAllowed ? 'Fumeur accepte' : 'Non fumeur' }}
								</span>
								<span class="badge text-bg-light border text-dark">
									{{ trip.driver.driverPreferences.petsAllowed ? 'Animaux acceptes' : 'Animaux non acceptes' }}
								</span>
								{% for extra in trip.driver.driverPreferences.extras %}
									<span class="badge text-bg-light border text-dark">{{ extra }}</span>
								{% endfor %}
							</div>
						{% endif %}
					</div>
				</div>
			</div>

			<div class="col-12 col-lg-4">
				<div class="card border-0 shadow-sm rounded-4">
					<div class="card-body p-4">
						<h2 class="h5 text-secondary mb-3">Participer au covoiturage</h2>

						{% if app.user is null %}
							<p class="text-muted">Connecte-toi pour participer a ce covoiturage.</p>
							<a href="{{ path('app_login') }}" class="btn btn-primary text-white w-100">Se connecter</a>
						{% elseif trip.driver == app.user %}
							<div class="alert alert-info mb-0">C est ton covoiturage.</div>
						{% elseif existingBooking %}
							<div class="alert alert-success mb-0">Tu participes deja a ce covoiturage.</div>
						{% elseif trip.seatsAvailable <= 0 %}
							<div class="alert alert-warning mb-0">Ce covoiturage est complet.</div>
						{% elseif canParticipate %}
							<form method="post" action="{{ path('app_carpooling_participate', {id: trip.id}) }}">
								<input type="hidden" name="_token" value="{{ csrf_token('participate_trip_' ~ trip.id) }}">
								<button type="submit" class="btn btn-primary text-white w-100">Participer a ce covoiturage</button>
							</form>
						{% endif %}
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
